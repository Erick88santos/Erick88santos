import pygame
pygame.init()
x = 400
y = 300
velocidade = 10
fundo = pygame.image.load('fundo.png') 
carro = pygame.image.load('carro.png')
carro2 = pygame.image.load('carro2.png')

janela = pygame.display.set_mode((800,750))
pygame.display.set_caption("Criando um jogo em Python")

janela_aberta = True
while janela_aberta:
    pygame.time.delay(50)

    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            janela_aberta = False


    comandos = pygame.key.get_pressed()
    if comandos[pygame.K_UP]:
        y-= velocidade
    if comandos[pygame.K_DOWN]:
        y+= velocidade
    if comandos[pygame.K_LEFT]:
        x-= velocidade
    if comandos[pygame.K_RIGHT]:
        x+= velocidade


    comandos2 = pygame.key.get_pressed()
    if comandos[pygame.K_w]:
        y -= velocidade
    if comandos[pygame.K_s]:
        y += velocidade
    if comandos[pygame.K_a]:
        x -= velocidade
    if comandos[pygame.K_d]:
        x += velocidade

    janela.blit(fundo, (0,0))
    janela.blit(carro,(x,y))
    #janela.bakhoot(carro2, (x, y))
    pygame.display.update()

pygame.quit()
